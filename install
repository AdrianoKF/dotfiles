#!/usr/bin/env bash
set -euo pipefail

MAIN_CONFIG=install.conf.yaml

BASEDIR=$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")
DOTBOT_DIR="${BASEDIR}/dotbot"
DOTBOT_BIN="${DOTBOT_DIR}/bin/dotbot"

_install() {
    local config=$1
    shift
    local args=("$@")

    "${DOTBOT_BIN}" -d "${BASEDIR}" -c "${config}" "${args[@]}"
}

cd "${BASEDIR}"

# Dotbot setup
git -C "${DOTBOT_DIR}" submodule sync --quiet --recursive
git submodule update --init --recursive "${DOTBOT_DIR}"

"${DOTBOT_BIN}" --version

# Install main config
_install "$MAIN_CONFIG" "${@}"

# Linux-specific config (install-linux.conf.yaml)
if [[ "$(uname -s)" == "Linux" ]]; then
    LINUX_CONFIG="install-linux.conf.yaml"
    echo "Installing Linux-specific dotfiles from ${LINUX_CONFIG}."
    _install "$LINUX_CONFIG" "${@}"
fi

# Arch/Manjaro-specific config (install-arch.conf.yaml)
OS_ID=$(grep -oP '(?<=^ID=).+' /etc/os-release | tr -d '"')
if [[ "$OS_ID" == "arch" || "$OS_ID" == "manjaro" ]]; then
    echo "Installing packages for Arch-based systems."
    ./packages/arch.sh

    ARCH_CONFIG="install-arch.conf.yaml"
    echo "Installing additional dotfiles for Arch-based systems from ${ARCH_CONFIG}."
    _install "$ARCH_CONFIG" "${@}"
fi

# Host-specific dotfiles (pattern: install-[HOSTNAME].conf.yaml)
HOSTNAME=$(hostname)
HOST_CONFIG="install-$HOSTNAME.conf.yaml"
if [[ -f "$HOST_CONFIG" ]]; then
    echo "Installing host-specific dotfiles from ${HOST_CONFIG}"
    _install "$HOST_CONFIG" "${@}"
fi
